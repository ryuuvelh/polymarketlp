# Required only for live quoting (not for scanning)
PRIVATE_KEY=
CLOB_API_KEY=
CLOB_SECRET=
CLOB_PASS_PHRASE=

# Polymarket proxy wallet (signature_type=1 email, 2 browser wallet)
FUNDER_ADDRESS=
SIGNATURE_TYPE=2

# Required for run / tiered quoting (no default — set your budget)
TOTAL_CAPITAL_USD=

# Risk controls
NEAR_EXPIRY_HOURS=3
KILL_SWITCH_PRICE_DELTA=0.04
KILL_SWITCH_WINDOW_SEC=5
VOLUME_SPIKE_MULTIPLIER=3.0
KILL_COOLDOWN_SEC=60
TIER_ACTIVE_PCT=0.15
TIER_BUFFER_PCT=0.25
INVENTORY_IMBALANCE_PCT=0.30
MAX_OPEN_MARKETS=1
MAX_SKEW_CENTS=2.0

# Optional news feed API keys (Google News RSS works without keys)
NEWSAPI_KEY=
GNEWS_API_KEY=
CURRENTS_API_KEY=
FINNHUB_API_KEY=
NEWS_CACHE_TTL_SEC=300
